# Backend env — used when running the backend directly (outside Docker).
# For Docker-based dev, use the root .env instead.
# For AWS production, set these as ECS task env vars or via SSM Parameter Store.

# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database — point at RDS endpoint for AWS
DB_NAME=dndmap
DB_USER=dnduser
DB_PASSWORD=your-db-password
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432

# Email via AWS SES
# Setup: SES → Verified Identities (verify your domain), then
#         SES → SMTP Settings → Create SMTP credentials
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-ses-smtp-username
EMAIL_HOST_PASSWORD=your-ses-smtp-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
CONTACT_EMAIL=you@yourdomain.com

# Anthropic (map analysis agent)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
