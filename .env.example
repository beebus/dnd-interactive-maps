# Local dev — copy to .env and fill in values.
# docker compose up reads this automatically.

# Postgres container credentials (used by the db service)
POSTGRES_DB=dndmap
POSTGRES_USER=dnduser
POSTGRES_PASSWORD=devpassword

# Django DB connection (points at the db container)
DB_NAME=dndmap
DB_USER=dnduser
DB_PASSWORD=devpassword
DB_HOST=db
DB_PORT=5432

# Django
SECRET_KEY=dev-only-insecure-key-change-for-production
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Email — console backend prints to stdout; no SMTP setup needed for dev
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
CONTACT_EMAIL=you@example.com

# Optional — only needed if running the map-locations agent locally
ANTHROPIC_API_KEY=
